---
import "../styles/global.css";

const { title = "Anchor Ports" } = Astro.props;
---

<!doctype html>
<html lang="ja">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <meta
      name="description"
      content="Anchor Ports is a cyber nautical guide to network port order, collision risk, and finite resource management."
    />
    <title>{title}</title>
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link
      href="https://fonts.googleapis.com/css2?family=JetBrains+Mono:wght@400;600;700&family=Pirata+One&display=swap"
      rel="stylesheet"
    />
  </head>
  <body class="min-h-screen bg-abyss text-mist antialiased">
    <slot />
  </body>
</html>
